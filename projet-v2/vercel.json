{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/api/auth/login.js" },
    { "source": "/api/auth/init", "destination": "/api/auth/init.js" },
    { "source": "/api/inscrits/stats", "destination": "/api/inscrits/stats.js" },
    { "source": "/api/inscrits/:id", "destination": "/api/inscrits/[id].js" },
    { "source": "/api/inscrits", "destination": "/api/inscrits/index.js" },
    { "source": "/api/users/password", "destination": "/api/users/password.js" },
    { "source": "/api/users/:id", "destination": "/api/users/[id].js" },
    { "source": "/api/users", "destination": "/api/users/index.js" }
  ]
}
